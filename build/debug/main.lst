 219:Core/Src/main.c **** /**
 220:Core/Src/main.c ****   * @brief  Загрузить CLUT (Color Look-Up Table) для L8
 221:Core/Src/main.c ****   * @note   Запись 0 → чёрный, 255 → белый
 222:Core/Src/main.c ****   */
 223:Core/Src/main.c **** void LoadCLUT(void)
 224:Core/Src/main.c **** {
 225:Core/Src/main.c ****   uint32_t clut[256];
 226:Core/Src/main.c **** 
 227:Core/Src/main.c ****   for (int i = 0; i < 256; i++) {
 228:Core/Src/main.c ****     uint8_t gray = i;                     // градация серого
 229:Core/Src/main.c ****     clut[i] = (gray << 16) | (gray << 8) | gray; // RGB
 230:Core/Src/main.c ****   }
 231:Core/Src/main.c **** 
 232:Core/Src/main.c ****   if (HAL_LTDC_ConfigCLUT(&hltdc, clut, 256, LTDC_LAYER_1) != HAL_OK) {
 233:Core/Src/main.c ****     Error_Handler();
 234:Core/Src/main.c ****   }
 235:Core/Src/main.c **** }
