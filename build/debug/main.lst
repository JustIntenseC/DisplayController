 149:Core/Src/main.c **** void LTDC_FSM_Handle(LTDC_Block_t *lt){
 150:Core/Src/main.c ****     static uint8_t last_display_enabled = 0 ;
 151:Core/Src/main.c ****     switch (lt->state)
 152:Core/Src/main.c ****     {
 153:Core/Src/main.c ****         
 154:Core/Src/main.c ****     case FSM_IDLE:
 155:Core/Src/main.c ****       if(last_display_enabled != display_enabled){
 156:Core/Src/main.c ****         last_display_enabled = display_enabled;
 157:Core/Src/main.c ****         uint8_t color = display_enabled ? 0x00 : 0xFF;
 158:Core/Src/main.c ****         FillFrameBuffer(color, lt->frame_buffer);
 159:Core/Src/main.c ****       }
 160:Core/Src/main.c ****       else lt->state = FSM_START_FRAME;
 161:Core/Src/main.c **** 
 162:Core/Src/main.c ****     break;
 163:Core/Src/main.c **** 
 164:Core/Src/main.c ****     case FSM_START_FRAME:
 165:Core/Src/main.c ****        lt->state = FSM_RUNNING;
 166:Core/Src/main.c ****     break;
 167:Core/Src/main.c **** 
 168:Core/Src/main.c ****     case FSM_RUNNING:
 169:Core/Src/main.c ****       if(lt->frame_status){
 170:Core/Src/main.c ****         lt->frame_status = FRAME_NOT_READY;
 171:Core/Src/main.c ****         lt->state = FSM_END_FRAME;
 172:Core/Src/main.c ****       }
 173:Core/Src/main.c ****     break;
 174:Core/Src/main.c **** 
 175:Core/Src/main.c ****     case FSM_END_FRAME:
 176:Core/Src/main.c ****       lt->state = FSM_IDLE;
 177:Core/Src/main.c ****     break;
 178:Core/Src/main.c **** 
 179:Core/Src/main.c ****     default:
 180:Core/Src/main.c ****         break;
 181:Core/Src/main.c ****     }
 182:Core/Src/main.c **** }
