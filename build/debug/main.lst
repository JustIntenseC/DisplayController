 153:Core/Src/main.c **** void LTDC_FSM_Handle(LTDC_Block_t *lt){
 154:Core/Src/main.c ****     switch (lt->state)
 155:Core/Src/main.c ****     {
 156:Core/Src/main.c ****         
 157:Core/Src/main.c ****     case FSM_IDLE:
 158:Core/Src/main.c ****       if(!display_enabled){
