 153:Core/Src/main.c ****         
 154:Core/Src/main.c ****     case FSM_IDLE:
 155:Core/Src/main.c ****       if(flag_ltdc_work){
 156:Core/Src/main.c ****         FillFrameBuffer(0x00, MainLTDC->frame_buffer);
 157:Core/Src/main.c ****         MainLTDC->state = FSM_START_FRAME;
 158:Core/Src/main.c ****       }
