 160:Core/Src/main.c ****         FillFrameBuffer(color, lt->frame_buffer);
 161:Core/Src/main.c ****       }
 162:Core/Src/main.c ****       else lt->state = FSM_START_FRAME;
 163:Core/Src/main.c **** 
 164:Core/Src/main.c ****     break;
 165:Core/Src/main.c **** 
 166:Core/Src/main.c ****     case FSM_START_FRAME:
 167:Core/Src/main.c ****        lt->state = FSM_RUNNING;
 168:Core/Src/main.c ****     break;
 169:Core/Src/main.c **** 
 170:Core/Src/main.c ****     case FSM_RUNNING:
